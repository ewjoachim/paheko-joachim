{
  extends: ["config:recommended", ":enablePreCommit"],
  schedule: ["before 4am on Saturday"],
  labels: ["deps"],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
  },
  packageRules: [
    {
      groupName: "all dependencies",
      groupSlug: "all",
      matchPackageNames: ["*"],
    },
  ],
  automerge: true,
}
